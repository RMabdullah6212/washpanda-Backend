{
  "name": "washpanda-backend",
  "version": "1.0.0",
  "description": "WashPanda REST API",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "seed:gallery": "node src/scripts/seedGallery.js",
    "seed:vehicles": "node src/scripts/seedVehicleImages.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "check": "node --check src/server.js && node --check src/app.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "zod": "^4.1.12"
  }
}
